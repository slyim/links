---
import '../styles/main.css';
import BackgroundOrbs from '../components/BackgroundOrbs.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Profile from '../components/Profile.astro';
import LinkButton from '../components/LinkButton.astro';
import DiscordCopy from '../components/DiscordCopy.astro';

// Page Title and SEO metadata
const title = "Lila — Digital Space & Creative Showcase";
const description = "Hi, I'm Lila. I create products for humans.";
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    
    <!-- Theme Script - Blocking script in head to prevent styling flashes -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        if (saved) {
          document.documentElement.setAttribute('data-theme', saved);
        } else {
          const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          document.documentElement.setAttribute('data-theme', prefersLight ? 'light' : 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <!-- Skip to content for accessibility -->
    <a href="#main-content" class="skip-link">Skip to Content</a>

    <!-- Animated Neon Blobs Background -->
    <BackgroundOrbs />

    <!-- Theme Switcher -->
    <ThemeToggle />

    <!-- Main Viewport Center -->
    <main id="main-content" class="container">
      <div class="inner-layout stagger-children">
        
        <!-- Profile details -->
        <Profile 
          name="Lila"
          handle="@liladesign"
          description="Hi, I'm Lila. I create products for humans."
        />

        <!-- Links Grid Section -->
        <section class="links-section stagger-children" aria-label="Links grid">
          <div class="animate-fade-in-up">
            <LinkButton 
              href="https://liladesign.dev" 
              title="Portfolio" 
              icon="globe"
            />
          </div>

          <div class="animate-fade-in-up">
            <LinkButton 
              href="https://github.com/slyim" 
              title="GitHub" 
              icon="github"
            />
          </div>

          <div class="animate-fade-in-up">
            <LinkButton 
              href="https://bsky.app/profile/violila.bsky.social" 
              title="Bluesky" 
              icon="bluesky"
            />
          </div>

          <div class="animate-fade-in-up">
            <LinkButton 
              href="https://www.instagram.com/violilygirl/" 
              title="Instagram" 
              icon="instagram"
            />
          </div>

          <div class="animate-fade-in-up">
            <LinkButton 
              href="https://dribbble.com/Shylesiana" 
              title="Dribbble" 
              icon="dribbble"
            />
          </div>

          <div class="animate-fade-in-up">
            <LinkButton 
              href="https://www.behance.net/eb0aa8d3" 
              title="Behance" 
              icon="behance"
            />
          </div>

          <div class="animate-fade-in-up">
            <DiscordCopy 
              username="violily"
              label="violily"
            />
          </div>
        </section>


        <!-- Footer -->
        <footer class="footer animate-fade-in-scale">
          <div class="footer-divider" aria-hidden="true"></div>
          <p class="footer-credit">
            © {new Date().getFullYear()} Lila. All rights reserved.
          </p>
          <div class="footer-meta-links">
            <a href={`${import.meta.env.BASE_URL}privacy`} class="footer-link">Privacy</a>
            <span class="footer-bullet">•</span>
            <a href={`${import.meta.env.BASE_URL}terms`} class="footer-link">Terms</a>
          </div>
        </footer>

      </div>
    </main>
  </body>
</html>

<style>
  /* Base Container Grid styling */
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    min-height: 100dvh;
    padding: 60px 20px 48px;
    width: 100%;
    position: relative;
    z-index: 10;
  }

  .inner-layout {
    width: 100%;
    max-width: 520px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }

  /* Links section formatting */
  .links-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
  }

  .widget-section,
  .contact-section {
    width: 100%;
  }

  /* Footer Details */
  .footer {
    width: 100%;
    margin-top: 40px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .footer-divider {
    width: 60px;
    height: 1px;
    background: var(--border-color);
    margin-bottom: 8px;
  }

  .footer-credit {
    font-size: 0.78rem;
    font-weight: 300;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .footer-meta-links {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer-link {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-link:hover {
    color: var(--accent-color);
  }

  .footer-bullet {
    font-size: 0.65rem;
    color: var(--border-color);
  }

  @media (max-width: 480px) {
    .container {
      padding: 72px 16px 36px; /* Extra top padding to clear mobile top theme toggle */
    }
    .inner-layout {
      gap: 12px;
    }
    .footer {
      margin-top: 32px;
    }
  }
</style>
