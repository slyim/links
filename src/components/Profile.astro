---
interface Props {
  name: string;
  handle: string;
  description: string;
}

const { name, handle, description } = Astro.props;
---

<div class="profile-container animate-fade-in-scale">
  <!-- Avatar wrapper with clean styling -->
  <div class="avatar-wrapper">
    <div class="avatar-inner">
      <img 
        src="/avatar.png" 
        alt={`${name}'s Avatar`} 
        class="avatar-image" 
        loading="eager"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div class="avatar-placeholder">
        <span class="avatar-initials">{name.split(' ').map(n => n[0]).join('')}</span>
      </div>
    </div>
  </div>

  <!-- Name and Handle -->
  <h1 class="profile-name">{name}</h1>
  <p class="profile-handle">{handle}</p>

  <!-- Description / Bio -->
  <p class="profile-bio">{description}</p>
</div>

<style>
  .profile-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    margin-bottom: 24px;
  }

  /* Avatar Circle Wrapper */
  .avatar-wrapper {
    position: relative;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    margin-bottom: 20px;
    padding: 3px;
    background: var(--border-color);
  }

  .avatar-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-background-soft);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .avatar-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid var(--bg-page);
    z-index: 2;
  }

  .avatar-placeholder {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: var(--color-background-soft);
    border: 3px solid var(--bg-page);
    border-radius: 50%;
    z-index: 1;
  }

  .avatar-initials {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--accent-color);
    letter-spacing: -0.05em;
  }

  /* Name & Handle */
  .profile-name {
    font-size: clamp(1.8rem, 4vw, 2.2rem);
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 4px;
  }

  .profile-handle {
    font-size: 1rem;
    font-weight: 500;
    color: var(--accent-color);
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  /* Bio Description */
  .profile-bio {
    font-size: clamp(0.95rem, 2vw, 1.05rem);
    font-weight: 300;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.6;
    margin: 0 auto;
  }

  /* Responsive Adjustments */
  @media (max-width: 480px) {
    .avatar-wrapper {
      width: 100px;
      height: 100px;
    }
  }
</style>
