---
interface Props {
  class?: string;
  [key: string]: any;
}

const { class: className, ...rest } = Astro.props;
---

<div class:list={["glass-card", className]} {...rest}>
  <div class="glass-border" aria-hidden="true"></div>
  <div class="card-inner">
    <div class="glass-content">
      <slot />
    </div>
  </div>
</div>

<style>
  .glass-card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 20px;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    transition: border-color 0.3s ease;
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
  }

  .glass-card:hover {
    border-color: transparent;
  }

  /* Animated Border Overlay */
  .glass-border {
    position: absolute;
    inset: 0;
    border-radius: 20px;
    padding: 1.5px;
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .glass-border::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 300%;
    aspect-ratio: 1;
    background: conic-gradient(
      from 0deg,
      transparent 50%,
      rgba(var(--accent-rgb), 0.1) 65%,
      var(--accent-color) 85%,
      transparent 100%
    );
    transform: translate(-50%, -50%) rotate(0deg);
    animation: spin 4s linear infinite;
    animation-play-state: paused;
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }

  .glass-card:hover .glass-border::before {
    opacity: 1;
    animation-play-state: running;
  }

  /* Inner Card Content Base */
  .card-inner {
    position: relative;
    margin: 1.5px;
    width: calc(100% - 3px);
    flex-grow: 1;
    border-radius: 18.5px;
    background: var(--bg-card);
    z-index: 1;
    display: flex;
    flex-direction: column;
  }

  .glass-content {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
  }

  @keyframes spin {
    0%   { transform: translate(-50%, -50%) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @media (max-width: 768px) {
    .glass-card {
      border-radius: 16px;
    }
    .card-inner {
      border-radius: 14.5px;
    }
    .glass-border {
      border-radius: 16px;
    }
  }

  @media (max-width: 480px) {
    .glass-card {
      border-radius: 14px;
    }
    .card-inner {
      border-radius: 12.5px;
    }
    .glass-border {
      border-radius: 14px;
    }
  }
</style>
