---
---

<div class="orbs-container" id="interactive-container" aria-hidden="true">
  <!-- Faint base grid visible everywhere -->
  <div class="grid-base"></div>
  
  <!-- Subtle cursor glow that follows mouse -->
  <div class="spotlight-glow"></div>
  
  <!-- Highlighted spotlight grid that lights up around the cursor -->
  <div class="grid-spotlight"></div>
</div>

<style>
  .orbs-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }

  /* Static faint base grid */
  .grid-base {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 44px 44px;
    background-position: center center;
    opacity: 1;
    z-index: 0;
    pointer-events: none;
  }

  /* Faint accent cursor spotlight glow */
  .spotlight-glow {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle 220px at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(208, 255, 0, 0.04) 0%,
      transparent 100%
    );
    z-index: 1;
    pointer-events: none;
    will-change: background-image;
  }

  /* Highlighted spotlight grid */
  .grid-spotlight {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(208, 255, 0, 0.16) 1px, transparent 1px),
      linear-gradient(90deg, rgba(208, 255, 0, 0.16) 1px, transparent 1px);
    background-size: 44px 44px;
    background-position: center center;
    z-index: 2;
    pointer-events: none;
    will-change: mask-image, -webkit-mask-image;
    
    /* Radial mask centered on mouse cursor */
    -webkit-mask-image: radial-gradient(
      circle 200px at var(--mouse-x, 50%) var(--mouse-y, 50%), 
      rgba(0, 0, 0, 1) 0%, 
      rgba(0, 0, 0, 0.15) 60%, 
      transparent 100%
    );
    mask-image: radial-gradient(
      circle 200px at var(--mouse-x, 50%) var(--mouse-y, 50%), 
      rgba(0, 0, 0, 1) 0%, 
      rgba(0, 0, 0, 0.15) 60%, 
      transparent 100%
    );
  }

  /* Light theme adaptation */
  :global(html[data-theme="light"]) .grid-base {
    background-image: 
      linear-gradient(rgba(0, 0, 0, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.015) 1px, transparent 1px);
  }

  :global(html[data-theme="light"]) .spotlight-glow {
    background-image: radial-gradient(
      circle 220px at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(82, 163, 0, 0.03) 0%,
      transparent 100%
    );
  }

  :global(html[data-theme="light"]) .grid-spotlight {
    background-image: 
      linear-gradient(rgba(82, 163, 0, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(82, 163, 0, 0.12) 1px, transparent 1px);
  }
</style>

<script>
  function setupInteractiveGrid() {
    const container = document.getElementById('interactive-container');
    if (!container) return;

    // Centered default coordinate fallback for mobile/load
    container.style.setProperty('--mouse-x', '50%');
    container.style.setProperty('--mouse-y', '50%');

    const updateCoordinates = (x: number, y: number) => {
      // GPU-friendly custom properties update on the shared parent container
      container.style.setProperty('--mouse-x', `${x}px`);
      container.style.setProperty('--mouse-y', `${y}px`);
    };

    // Mouse tracking
    window.addEventListener('mousemove', (e) => {
      updateCoordinates(e.clientX, e.clientY);
    });

    // Touch tracking (mobile)
    window.addEventListener('touchmove', (e) => {
      if (e.touches.length > 0) {
        updateCoordinates(e.touches[0].clientX, e.touches[0].clientY);
      }
    }, { passive: true });
  }

  // Set up on load
  setupInteractiveGrid();

  // Support Astro View Transitions after-swap lifecycle
  document.addEventListener('astro:after-swap', setupInteractiveGrid);
</script>

