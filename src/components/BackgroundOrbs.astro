<div class="orbs-container" aria-hidden="true">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="orb orb-4"></div>
</div>

<style>
  .orbs-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    opacity: 0.3;
    will-change: transform;
  }

  .orb-1 {
    width: min(500px, 80vw);
    height: min(500px, 80vw);
    top: -10%;
    left: -5%;
    background: radial-gradient(circle, rgba(208, 255, 0, 0.22) 0%, transparent 70%);
    animation: orbFloat1 22s ease-in-out infinite alternate;
  }

  .orb-2 {
    width: min(400px, 70vw);
    height: min(400px, 70vw);
    top: 40%;
    right: -8%;
    background: radial-gradient(circle, rgba(208, 255, 0, 0.16) 0%, transparent 70%);
    animation: orbFloat2 28s ease-in-out infinite alternate;
  }

  .orb-3 {
    width: min(350px, 60vw);
    height: min(350px, 60vw);
    bottom: 5%;
    left: 15%;
    background: radial-gradient(circle, rgba(208, 255, 0, 0.14) 0%, transparent 70%);
    animation: orbFloat3 20s ease-in-out infinite alternate;
  }

  .orb-4 {
    width: min(300px, 50vw);
    height: min(300px, 50vw);
    bottom: 30%;
    right: 15%;
    background: radial-gradient(circle, rgba(208, 255, 0, 0.11) 0%, transparent 70%);
    animation: orbFloat4 24s ease-in-out infinite alternate;
  }

  @keyframes orbFloat1 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(60px, 80px) scale(1.1); }
  }

  @keyframes orbFloat2 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-50px, 60px) scale(1.15); }
  }

  @keyframes orbFloat3 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(70px, -45px) scale(1.08); }
  }

  @keyframes orbFloat4 {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-30px, -70px) scale(1.12); }
  }

  /* Light theme: Adjust colors for maximum contrast and aesthetics */
  :global(html[data-theme="light"]) .orb {
    opacity: 0.18;
  }

  :global(html[data-theme="light"]) .orb-1 {
    background: radial-gradient(circle, rgba(82, 163, 0, 0.18) 0%, transparent 70%);
  }

  :global(html[data-theme="light"]) .orb-2 {
    background: radial-gradient(circle, rgba(82, 163, 0, 0.14) 0%, transparent 70%);
  }

  :global(html[data-theme="light"]) .orb-3 {
    background: radial-gradient(circle, rgba(82, 163, 0, 0.11) 0%, transparent 70%);
  }

  :global(html[data-theme="light"]) .orb-4 {
    background: radial-gradient(circle, rgba(82, 163, 0, 0.08) 0%, transparent 70%);
  }
</style>
