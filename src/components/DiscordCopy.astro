---
import Icon from './Icon.astro';

interface Props {
  username: string;
  label?: string;
}

const { username = 'violily', label = 'violily' } = Astro.props;
---

<button class="discord-btn" id="discord-copy-btn" data-username={username} aria-label={`Copy Discord tag: ${username}`}>
  <!-- Glowing border that spins on hover -->
  <div class="link-border" aria-hidden="true"></div>
  
  <div class="link-inner">
    <div class="link-icon-wrapper">
      <Icon name="discord" class="link-icon" />
    </div>
    
    <div class="link-text">
      <span class="link-title">{label}</span>
      <span class="link-subtitle" id="discord-subtitle">Copied to clipboard!</span>
    </div>

    <div class="link-meta">
      <span class="copy-badge" id="copy-badge">
        <!-- Copy Icon (default state) -->
        <Icon name="copy" class="copy-badge-icon default-icon" />
        <!-- Check Icon (copied state) -->
        <svg class="check-icon copy-badge-icon" viewBox="0 0 256 256" width="16" height="16" fill="currentColor">
          <path d="M104,192a8.5,8.5,0,0,1-5.7-2.3l-56-56a8.1,8.1,0,0,1,11.4-11.4l50.3,50.3L206.3,70.3a8.1,8.1,0,0,1,11.4,11.4l-108,108A8.5,8.5,0,0,1,104,192Z"/>
        </svg>
      </span>
    </div>
  </div>
</button>

<style>
  .discord-btn {
    position: relative;
    display: flex;
    text-decoration: none;
    border-radius: 16px;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    transition: 
      border-color 0.3s ease, 
      transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow: hidden;
    color: var(--text-primary);
    width: 100%;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    padding: 0;
  }

  .discord-btn:hover {
    border-color: transparent;
    transform: translateY(-3px);
  }

  .discord-btn:active {
    transform: translateY(-1px);
  }

  /* Conic animated border overlay */
  .link-border {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 1.5px;
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .link-border::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 300%;
    aspect-ratio: 1;
    background: conic-gradient(
      from 0deg,
      transparent 55%,
      rgba(var(--accent-rgb), 0.15) 70%,
      var(--accent-color) 88%,
      transparent 100%
    );
    transform: translate(-50%, -50%) rotate(0deg);
    animation: spin 3.5s linear infinite;
    animation-play-state: paused;
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }

  .discord-btn:hover .link-border::before {
    opacity: 1;
    animation-play-state: running;
  }

  /* Inner elements structure */
  .link-inner {
    position: relative;
    margin: 1.5px;
    width: calc(100% - 3px);
    border-radius: 14.5px;
    background: var(--bg-card);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    z-index: 1;
    transition: background 0.3s ease;
  }

  .discord-btn:hover .link-inner {
    background: rgba(0, 0, 0, 0.25);
  }

  :global(html[data-theme="light"]) .link-inner {
    background: rgba(255, 255, 255, 0.7);
  }
  
  :global(html[data-theme="light"]) .discord-btn:hover .link-inner {
    background: rgba(255, 255, 255, 0.85);
  }

  /* Icon wrapper styling */
  .link-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(var(--accent-rgb), 0.08);
    border: 1px solid rgba(var(--accent-rgb), 0.15);
    color: var(--accent-color);
    transition: transform 0.3s ease, background 0.3s ease, border-color 0.3s ease;
  }

  .discord-btn:hover .link-icon-wrapper {
    transform: scale(1.08) rotate(-4deg);
    background: rgba(var(--accent-rgb), 0.15);
    border-color: rgba(var(--accent-rgb), 0.35);
  }

  .link-icon {
    width: 22px;
    height: 22px;
  }

  /* Text details */
  .link-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex-grow: 1;
    gap: 0;
  }

  .link-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    transition: color 0.3s ease;
    line-height: 1.2;
  }

  .discord-btn:hover .link-title {
    color: var(--accent-color);
  }

  /* Subtitle starts hidden and slides down when copied */
  .link-subtitle {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--accent-color);
    text-align: left;
    line-height: 1.3;
    opacity: 0;
    max-height: 0px;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* Copied active state triggers slide down */
  .discord-btn.copied .link-subtitle {
    opacity: 1;
    max-height: 20px;
    margin-top: 4px;
  }

  /* Copy badge and state transition styling */
  .link-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .copy-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--text-muted);
    background: rgba(var(--text-rgb), 0.05);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .discord-btn:hover .copy-badge {
    color: var(--accent-color);
    border-color: rgba(var(--accent-rgb), 0.3);
    background: rgba(var(--accent-rgb), 0.05);
  }

  .copy-badge-icon {
    width: 16px;
    height: 16px;
  }

  .default-icon {
    opacity: 1;
    transform: scale(1);
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .check-icon {
    position: absolute;
    opacity: 0;
    transform: scale(0.6);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* Copied active state badge */
  .discord-btn.copied .copy-badge {
    color: #000;
    background: var(--accent-color);
    border-color: var(--accent-color);
    box-shadow: 0 0 12px rgba(var(--accent-rgb), 0.45);
  }

  .discord-btn.copied .default-icon {
    opacity: 0;
    transform: scale(0.6);
  }

  .discord-btn.copied .check-icon {
    opacity: 1;
    transform: scale(1);
  }

  @keyframes spin {
    0%   { transform: translate(-50%, -50%) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* Responsive tweaks */
  @media (max-width: 480px) {
    .link-inner {
      padding: 14px 16px;
      gap: 12px;
    }
    .link-icon-wrapper {
      width: 38px;
      height: 38px;
    }
    .link-icon {
      width: 18px;
      height: 18px;
    }
    .link-title {
      font-size: 0.95rem;
    }
    .link-subtitle {
      font-size: 0.78rem;
    }
    .copy-badge {
      width: 28px;
      height: 28px;
      border-radius: 8px;
    }
    .copy-badge-icon {
      width: 14px;
      height: 14px;
    }
  }
</style>

<script>
  const btn = document.getElementById('discord-copy-btn');

  if (btn) {
    const username = btn.getAttribute('data-username') || 'violily';
    let timeoutId: any = null;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(username);
        
        // Add active style class
        btn.classList.add('copied');

        // Reset feedback after 2 seconds
        if (timeoutId) clearTimeout(timeoutId);
        timeoutId = setTimeout(() => {
          btn.classList.remove('copied');
        }, 2000);

      } catch (err) {
        console.error('Failed to copy text: ', err);
      }
    });
  }
</script>
